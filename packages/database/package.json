{
  "name": "@tradescore/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tradescore-db": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/cli.ts migrate",
    "migrate:status": "tsx src/cli.ts status",
    "seed": "tsx src/cli.ts seed",
    "seed:pilot": "tsx src/cli.ts seed:pilot",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@tradescore/config": "workspace:*",
    "@tradescore/logging": "workspace:*",
    "@tradescore/shared": "workspace:*",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
