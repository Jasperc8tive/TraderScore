# =============================================================================
# TradeScore — Environment Configuration (EXAMPLE)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Every value here is read through @tradescore/config and validated at startup.
# All config is env-driven so the same code runs locally and on AWS unchanged.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development

# ---- API service ------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated list of allowed web origins for CORS.
API_CORS_ORIGINS=http://localhost:3000

# ---- Web service ------------------------------------------------------------
WEB_PORT=3000
# Public base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- PostgreSQL -------------------------------------------------------------
# Host for tooling run OUTSIDE Docker (e.g. `pnpm db:migrate` from your shell):
# the Docker-published port on `localhost`. Inside Docker Compose the api service
# overrides this to the `postgres` service name via its `environment:` block, and
# production swaps in the RDS endpoint.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Host port Docker publishes Postgres on. Change this (e.g. 5433) if 5432 is
# already taken on your machine — it does NOT affect container-to-container access.
POSTGRES_HOST_PORT=5432
POSTGRES_USER=tradescore
POSTGRES_PASSWORD=tradescore_dev_password
POSTGRES_DB=tradescore
# Optional: full URL overrides the discrete vars above if set.
# DATABASE_URL=postgresql://tradescore:tradescore_dev_password@postgres:5432/tradescore
POSTGRES_SSL=false
POSTGRES_POOL_MAX=10

# ---- Redis ------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Host port Docker publishes Redis on. Change if 6379 is taken locally.
REDIS_HOST_PORT=6379
# REDIS_PASSWORD=
# REDIS_URL=redis://redis:6379

# ---- Authentication ---------------------------------------------------------
# Generate strong values for non-dev environments (e.g. `openssl rand -hex 32`).
JWT_ACCESS_SECRET=dev_access_secret_change_me_in_production_minimum_32_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_in_production_min_32_chars
JWT_ACCESS_TTL=900            # access token lifetime, seconds (15 min)
JWT_REFRESH_TTL=2592000       # refresh/session lifetime, seconds (30 days)
JWT_ISSUER=tradescore

# ---- OTP --------------------------------------------------------------------
OTP_TTL=300                   # OTP validity, seconds (5 min)
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN=60        # seconds between resend requests

# ---- Object storage (S3-compatible; future use, abstraction is cloud-ready) -
STORAGE_DRIVER=local          # local | s3
STORAGE_LOCAL_PATH=./.docker-data/uploads
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# ---- Observability ----------------------------------------------------------
LOG_LEVEL=debug               # trace | debug | info | warn | error
# SENTRY_DSN=
# POSTHOG_KEY=
